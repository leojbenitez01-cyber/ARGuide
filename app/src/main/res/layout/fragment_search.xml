<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ar_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_rounded_surface_14"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Atrás" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Buscar edificio, salón, servicio..."
                android:textColor="@color/ar_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Filters -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/filter_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filter_todo"
                    style="@style/FilterChip"
                    android:background="@drawable/bg_chip_orange"
                    android:textColor="@color/white"
                    android:text="Todo" />

                <TextView
                    android:id="@+id/filter_edificios"
                    style="@style/FilterChip"
                    android:background="@drawable/bg_chip_surface"
                    android:textColor="@color/ar_text_secondary"
                    android:text="Edificios" />

                <TextView
                    android:id="@+id/filter_laboratorios"
                    style="@style/FilterChip"
                    android:background="@drawable/bg_chip_surface"
                    android:textColor="@color/ar_text_secondary"
                    android:text="Laboratorios" />

                <TextView
                    android:id="@+id/filter_servicios"
                    style="@style/FilterChip"
                    android:layout_marginEnd="0dp"
                    android:background="@drawable/bg_chip_surface"
                    android:textColor="@color/ar_text_secondary"
                    android:text="Servicios" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Suggestions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sugerencias"
            android:textColor="@color/ar_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <include layout="@layout/item_search_row" android:id="@+id/sug_1" />
        <include layout="@layout/item_search_row" android:id="@+id/sug_2" />
        <include layout="@layout/item_search_row" android:id="@+id/sug_3" />
        <include layout="@layout/item_search_row" android:id="@+id/sug_4" />
        <include layout="@layout/item_search_row" android:id="@+id/sug_5" />

        <!-- Recent searches -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Búsquedas recientes"
                android:textColor="@color/ar_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limpiar"
                android:textColor="@color/ar_orange"
                android:textSize="13sp" />
        </LinearLayout>

        <include layout="@layout/item_recent_search" android:id="@+id/recent_1" />
        <include layout="@layout/item_recent_search" android:id="@+id/recent_2" />
        <include layout="@layout/item_recent_search" android:id="@+id/recent_3" />

    </LinearLayout>
</ScrollView>
